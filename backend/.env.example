# ==============================================================================
# AI Football Intelligence Platform - Backend Env Configuration Template
# Copy this file to .env in the same folder and fill in the values.
# ==============================================================================

# Core Settings
PROJECT_NAME="AI Football Intelligence Platform"
ENVIRONMENT="development" # development, staging, production
DEBUG=True
API_V1_STR="/api/v1"

# FastAPI Server Settings
HOST="0.0.0.0"
PORT=8000

# PostgreSQL Database (Supabase)
# In local development, you can point to a local PostgreSQL container or Supabase directly
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_ai"

# ChromaDB Vector Store
CHROMADB_HOST="localhost"
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME="tactical_knowledge_base"

# Gemini API Configuration
GEMINI_API_KEY="your-gemini-api-key-here"

# Authentication (Clerk Integration verification keys)
CLERK_API_KEY="your-clerk-api-key-here"
CLERK_JWT_KEY="your-clerk-jwt-verification-public-key-here"

# Storage Settings (Local file storage vs AWS S3/Supabase storage)
STORAGE_TYPE="local" # local, s3, supabase
UPLOAD_DIR="/Users/surajbhatt/Desktop/FootballAI/backend/uploads"
