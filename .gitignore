venv/
ENV/
env/

# Node caching & next builds
node_modules/
.next/
out/
build/
dist/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Database & Storage
data/
uploads/
/backend/uploads/
pg_data/
chroma_data/

