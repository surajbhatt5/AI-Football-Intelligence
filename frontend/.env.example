# ==============================================================================
# AI Football Intelligence Platform - Frontend Env Configuration Template
# Copy this file to .env.local in the same folder and fill in the values.
# ==============================================================================

# Public API routing (pointing to our FastAPI backend)
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

# Clerk Authentication (Clerk Dashboard - API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect routes (Standard Clerk configurations)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Optional Supabase integration keys (if interacting directly from front-end client)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key-here"
